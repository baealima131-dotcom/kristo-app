{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "apps/mobile",
    "_excluded-from-vercel",
    "app/(tabs)",
    "app/kingdom",
    "app/church",
    "app/church/ministry-chat",
    "app/poster-profile.tsx",
    "app/profile",
    "app/profile/privacy.tsx",
    "_restore_backup_before_unquarantine",
    "_archive-trash-before-delete",
    "_restore",
    "_bak",
    "backups",
    "disabled",
    ".kristo-dev",
    ".trash_baks"
  ]
}
