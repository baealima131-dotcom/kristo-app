  "version": "1.0.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "icons:generate": "node scripts/generate-kristo-v1-icons.mjs",
    "splash:sync-native": "node scripts/sync-native-splash.mjs",
    "start": "expo start",
    "start:dev": "expo start --dev-client -c --host lan --port 8084",
    "attach:ios": "node scripts/attach-ios-dev-client.mjs",
    "ios:pods": "cd ios && pod install",
    "ios:rebuild": "expo run:ios --device",
    "ios:rebuild:dev": "expo run:ios --device --configuration Debug",
    "native:verify": "node scripts/verify-native-modules.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
