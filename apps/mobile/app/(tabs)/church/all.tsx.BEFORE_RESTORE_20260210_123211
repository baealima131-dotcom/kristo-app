import React, { useEffect, useMemo, useState } from "react";
import { Pressable, ScrollView, StyleSheet, Text, View, useWindowDimensions, Alert } from "react-native";
import AsyncStorage from "@react-native-async-storage/async-storage";
import { Ionicons } from "@expo/vector-icons";
import { useRouter } from "expo-router";
import { useSafeAreaInsets } from "react-native-safe-area-context";

const VIP_BG = "#0B0F17";
const GOLD = "#D9B35F";
const FIRE = "#FF7A18";
const FIRE2 = "#FFB84A";
const MUTED = "rgba(255,255,255,0.72)";
const CARD = "rgba(13,17,26,0.92)";

const PAD = 16;
const GAP = 12;

const PINS_KEY = "kristo:church_all_pins:v2";
const MAX_PINS = 4;

type Tile = {
  key: string;
  title: string;
  subtitle: string;
  icon: keyof typeof Ionicons.glyphMap;
  href?: string;
};

export default function ChurchAllScreen() {
  const router = useRouter();
  const insets = useSafeAreaInsets();
  const { width } = useWindowDimensions();

  const cols = width >= 780 ? 3 : 2;
  const cardW = Math.floor((width - PAD * 2 - GAP * (cols - 1)) / cols);

  const tiles = useMemo<Tile[]>(
    () => [
      {
        key: "overview",
        title: "Church Overview",
        subtitle: "Members + ministries + trends",
        icon: "stats-chart-outline",
        href: "/(tabs)/church/overview",
      },
      {
        key: "serviceflow",
        title: "Service Flow",
        subtitle: "Timeline blocks + responsibilities",
        icon: "time-outline",
        href: "/(tabs)/church/service-flow",
      },
      {
        key: "ministries",
        title: "Ministries",
        subtitle: "Open ministries + members",
        icon: "people-outline",
        href: "/(tabs)/church/ministries",
      },
      {
        key: "notifications",
        title: "Notifications",
        subtitle: "Church updates & alerts",
        icon: "notifications-outline",
        href: "/(tabs)/church/notifications",
      },
      {
        key: "directory",
        title: "Members Directory",
        subtitle: "Members + leaders contacts",
        icon: "id-card-outline",
        href: "/(tabs)/church/members",
      },
    ],
    []
  );

  const tilesByKey = useMemo(() => {
    const m = new Map<string, Tile>();
    tiles.forEach((t) => m.set(t.key, t));
    return m;
  }, [tiles]);

  const [pins, setPins] = useState<string[]>([]);
  const isFull = pins.length >= MAX_PINS;

  useEffect(() => {
    (async () => {
      try {
        const raw = await AsyncStorage.getItem(PINS_KEY);
        if (!raw) return;
        const arr = JSON.parse(raw);
        if (Array.isArray(arr)) {
          const cleaned = arr
            .filter((k) => typeof k === "string" && tilesByKey.has(k))
            .slice(0, MAX_PINS);
          setPins(cleaned);
        }
      } catch {}
    })();
  }, [tilesByKey]);

  async function savePins(next: string[]) {
    setPins(next);
    try {
      await AsyncStorage.setItem(PINS_KEY, JSON.stringify(next));
    } catch {}
  }

  function go(href?: string) {
    if (!href) return;
    router.push(href as any);
  }

  function isPinned(key: string) {
    return pins.includes(key);
  }

  // VIP FLOW:
  // - max 4
  // - if user pins 5th => show alert (no auto-remove)
  
  // VIP FLOW:
  // - max 4
  // - if user pins 5th => show alert (no auto-remove)
  async function pinSmart(key: string) {
    if (isPinned(key)) {
      await savePins(pins.filter((k) => k !== key));
      return;
    }

    if (pins.length >= MAX_PINS) {
      Alert.alert("VIP PIN", "Unpin one item first (max 4).", [{ text: "OK" }]);
      return;
    }

    await savePins([...pins, key]);
  }

async function clearPins() {
    await savePins([]);
  }

  const pinnedTiles = pins.map((k) => tilesByKey.get(k)).filter(Boolean) as Tile[];

  return (
    <View style={[s.wrap, { paddingTop: insets.top + 12 }]}>
      {/* Header */}
      <View style={[s.topRow, { paddingHorizontal: PAD }]}>
        <Pressable onPress={() => router.back()} style={s.backBtn} hitSlop={10}>
          <Ionicons name="chevron-back" size={20} color="white" />
        </Pressable>

        <View style={{ flex: 1 }}>
          <Text style={s.h1}>All</Text>
          <Text style={s.h2}>Dashboards & tools</Text>
        </View>

        <Pressable onPress={clearPins} style={({ pressed }) => [s.smallBtn, pressed && { opacity: 0.9 }]}>
          <Ionicons name="trash-outline" size={16} color={MUTED} />
        </Pressable>
      </View>

      {/* VIP PIN (VIP frames inside) */}
      <View style={[s.vipPinWrap, { marginHorizontal: PAD }]}>
        <View pointerEvents="none" style={s.vipOuterFrame} />
        <View pointerEvents="none" style={s.vipInnerFrame} />
        <View pointerEvents="none" style={s.vipShineTop} />

        <View style={s.vipRow}>
          <View style={s.vipBadge}>
            <Ionicons name="flame" size={14} color={GOLD} />
            <Text style={s.vipBadgeText}>VIP PIN</Text>
          </View>

          <Text style={s.vipHint}>{`Pinned: ${pins.length}/${MAX_PINS}`}</Text>
        </View>

        <View style={s.pinsRow}>
          {pinnedTiles.length === 0 ? (
            <View style={s.emptyFrame}>
              <View pointerEvents="none" style={s.emptyOuter} />
              <View pointerEvents="none" style={s.emptyInner} />
              <Ionicons name="sparkles-outline" size={14} color={MUTED} />
              <Text style={s.emptyText}>Pin your top 4 dashboards</Text>
            </View>
          ) : (
            pinnedTiles.map((t) => (
              <Pressable
                key={t.key}
                onPress={() => go(t.href)}
                style={({ pressed }) => [s.pinMini, pressed && { opacity: 0.93 }]}
              >
                <View pointerEvents="none" style={s.pinMiniOuter} />
                <View pointerEvents="none" style={s.pinMiniInner} />
                <View pointerEvents="none" style={s.pinMiniShine} />

                <View style={s.pinMiniIcon}>
                  <Ionicons name={t.icon} size={14} color="white" />
                </View>

                <Text style={s.pinMiniText} numberOfLines={1}>
                  {t.title}
                </Text>

                <Pressable onPress={() => pinSmart(t.key)} hitSlop={10} style={s.pinMiniX}>
                  <Ionicons name="close" size={14} color={MUTED} />
                </Pressable>
              </Pressable>
            ))
          )}
        </View>
      </View>

      {/* Grid */}
      <ScrollView
        showsVerticalScrollIndicator={false}
        contentContainerStyle={{
          paddingHorizontal: PAD,
          paddingBottom: insets.bottom + 18,
          paddingTop: 12,
        }}
      >
        <View style={[s.grid, { gap: GAP }]}>
          {tiles.map((t) => {
            const pinned = isPinned(t.key);
            return (
              <Pressable
                key={t.key}
                onPress={() => go(t.href)}
                style={({ pressed }) => [
                  s.card,
                  { width: cardW },
                  pressed && { transform: [{ scale: 0.99 }], opacity: 0.96 },
                ]}
              >
                {/* premium double frame + shine */}
                <View pointerEvents="none" style={s.outerFrame} />
                <View pointerEvents="none" style={s.innerFrame} />
                <View pointerEvents="none" style={s.shineTop} />

                {/* FIRE PIN badge */}
                <Pressable
                  onPress={() => pinSmart(t.key)}
                  hitSlop={10}
                  style={({ pressed }) => [
                    s.fireBtn,
                    pinned ? s.fireBtnOn : s.fireBtnOff,
                    pressed && { opacity: 0.92 },
                  ]}
                >
                  <Ionicons name="flame" size={16} color={pinned ? "white" : MUTED} />
                </Pressable>

                <View style={s.iconWrap}>
                  <Ionicons name={t.icon} size={20} color="white" />
                </View>

                <View style={{ flex: 1 }} />

                <Text style={s.title} numberOfLines={1}>{t.title}</Text>
                <Text style={s.sub} numberOfLines={2}>{t.subtitle}</Text>

                <View style={s.chev}>
                  <Ionicons name="chevron-forward" size={18} color={MUTED} />
                </View>

                <View pointerEvents="none" style={s.ring1} />
                <View pointerEvents="none" style={s.ring2} />
              </Pressable>
            );
          })}
        </View>
      </ScrollView>
    </View>
  );
}

