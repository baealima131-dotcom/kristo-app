  padding: "8px 12px",
  borderRadius: 999,
  border: "1px solid rgba(255,255,255,0.14)",
  background: "rgba(0,0,0,0.18)",
  fontWeight: 950,
  opacity: 0.92,
  whiteSpace: "nowrap",
};

