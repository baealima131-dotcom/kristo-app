// app/(app)/dashboard/courtship/matches/page.tsx
"use client";

import type { CSSProperties } from "react";
import Link from "next/link";
import { useEffect, useMemo, useRef, useState } from "react";
import CourtshipTabs from "../_components/CourtshipTabs";
import { useCourtshipStore, type ChatSender } from "../_lib/courtshipStore";

type PresenceMap = Partial<Record<ChatSender, string>>;
type PresenceByMatch = Record<string, PresenceMap>;

const ONLINE_WINDOW_MS = 25_000;
const PRESENCE_POLL_MS = 12_000; // lighter
const UNREAD_POLL_MS = 12_000; // lighter

function isOnlineStamp(stamp?: string) {
  if (!stamp) return false;
  const t = +new Date(stamp);
  if (!Number.isFinite(t)) return false;
  return Date.now() - t <= ONLINE_WINDOW_MS;
}

function formatTimeShort(iso?: string) {
  if (!iso) return "";
  const t = +new Date(iso);
  if (!Number.isFinite(t)) return "";
  try {
    return new Date(t).toLocaleString(undefined, {
      month: "short",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
    });
  } catch {
    return "";
  }
}

function shortText(s?: string, n = 80) {
  const x = String(s || "").trim();
  if (!x) return "";
  if (x.length <= n) return x;
  return x.slice(0, n - 1) + "…";
}

function StepsChip({ ok, label }: { ok: boolean; label: string }) {
  return <span style={ok ? chipOk : chipOff}>{label}</span>;
}

export default function MatchesPage() {
  const store = useCourtshipStore();
  const viewer: ChatSender = store.mode;

  const idsKey = useMemo(() => store.matches.map((m) => m.id).join("|"), [store.matches]);

  // presence cache
  const [presenceByMatch, setPresenceByMatch] = useState<PresenceByMatch>({});
  const aliveRef = useRef(true);

  // ✅ guard against duplicate intervals (React StrictMode in dev)
  const unreadTimerRef = useRef<any>(null);
  const presenceTimerRef = useRef<any>(null);

  // collapsible detail per match
  const [openId, setOpenId] = useState<string | null>(null);

  const stats = useMemo(() => {
    const total = store.matches.length;
    const approved = store.matches.filter((m) => m.approved).length;
    const waiting = Math.max(total - approved, 0);
    return { total, approved, waiting };
  }, [store.matches]);

  // ✅ Unread summary polling (light)
  useEffect(() => {
    aliveRef.current = true;

    // clear old timer if any
    if (unreadTimerRef.current) clearInterval(unreadTimerRef.current);

    const tick = async () => {
      try {
        const ids = store.matches.map((m) => m.id);
        if (ids.length === 0) return;
        await store.fetchUnreadSummary(ids);
      } catch {}
    };

    tick();
    unreadTimerRef.current = setInterval(tick, UNREAD_POLL_MS);

    return () => {
      aliveRef.current = false;
      if (unreadTimerRef.current) clearInterval(unreadTimerRef.current);
      unreadTimerRef.current = null;
    };
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [idsKey, store.mode]);

  // ✅ Presence polling (light)
  useEffect(() => {
    aliveRef.current = true;

    // clear old timer if any
    if (presenceTimerRef.current) clearInterval(presenceTimerRef.current);

    const tick = async () => {
      try {
        const ids = store.matches.map((m) => m.id);
        if (ids.length === 0) {
          if (aliveRef.current) setPresenceByMatch({});
          return;
        }

        
        // ✅ ping my presence first (so others can see me online)
        await Promise.all(
          ids.map(async (id) => {
            try {
              await store.pingPresence(id, viewer);
            } catch {}
          })
        );

        const results = await Promise.all(
          ids.map(async (id) => {
            try {
              const json = await store.getPresence(id);
              const presence = (json?.presence || {}) as PresenceMap;
              return [id, presence] as const;
            } catch {
              return [id, {} as PresenceMap] as const;
            }
          })
        );

        if (!aliveRef.current) return;

        setPresenceByMatch((prev) => {
          const next: PresenceByMatch = { ...prev };
          let changed = false;

          for (const [id, p] of results) {
            const a = prev[id] || {};
            const b = p || {};

            if ((a.Sender || "") !== (b.Sender || "")) {
              next[id] = { ...(next[id] || {}), Sender: b.Sender };
              changed = true;
            }
            if ((a.Receiver || "") !== (b.Receiver || "")) {
              next[id] = { ...(next[id] || {}), Receiver: b.Receiver };
              changed = true;
            }
            if ((a.Pastor || "") !== (b.Pastor || "")) {
              next[id] = { ...(next[id] || {}), Pastor: b.Pastor };
              changed = true;
            }
          }

          // cleanup
          const idSet = new Set(ids);
          for (const k of Object.keys(next)) {
            if (!idSet.has(k)) {
              delete next[k];
              changed = true;
            }
          }

          return changed ? next : prev;
        });
      } catch {}
    };

    tick();
    presenceTimerRef.current = setInterval(tick, PRESENCE_POLL_MS);

    return () => {
      aliveRef.current = false;
      if (presenceTimerRef.current) clearInterval(presenceTimerRef.current);
      presenceTimerRef.current = null;
    };
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [idsKey, store.mode]);

  return (
    <div>
      <CourtshipTabs />

      <div style={topRow}>
        <div>
          <div style={pageTitle}>Matches</div>
          <div style={pageSub}>
            Flow: <b>Discover → Send Interest</b> → <b>Requests → Accept</b> → <b>Steps 1–3</b> →{" "}
            <b>Pastor Approval</b> → <b>Couple</b>
          </div>

          <div style={{ display: "flex", gap: 10, flexWrap: "wrap", marginTop: 10 }}>
            <span style={modePill}>Mode: {store.mode}</span>

            <button style={btnSoft} onClick={() => store.setMode("Sender")} disabled={store.loading}>
              Sender
            </button>
            <button style={btnSoft} onClick={() => store.setMode("Receiver")} disabled={store.loading}>
              Receiver
            </button>

            <button style={btnSoft} onClick={() => store.refreshAll()} disabled={store.loading}>
              {store.loading ? "Refreshing..." : "Refresh"}
            </button>
          </div>
        </div>

        <div style={vipBadge}>👑 VIP GOLD PURE</div>
      </div>

      {/* Stats compact */}
      <div style={statsCard}>
        <div style={statPill}>
          Total <b style={statNumber}>{stats.total}</b>
        </div>
        <div style={statPill}>
          Approved <b style={statNumber}>{stats.approved}</b>
        </div>
        <div style={statPill}>
          Waiting <b style={statNumber}>{stats.waiting}</b>
        </div>
        <div style={statPill}>
          Unread <b style={statNumber}>{store.totalUnread ?? 0}</b>
        </div>

        <Link style={btnGoldLink} href="/dashboard/courtship/pastor">
          Pastor Admin (Reset All)
        </Link>
      </div>

      {store.matches.length === 0 ? (
        <div style={empty}>
          Hakuna matches bado. Nenda <b>Discover</b> → Send Interest, kisha <b>Requests</b> (Receiver) → Accept.
        </div>
      ) : (
        <div style={listWrap}>
          {store.matches.map((m) => {
            const p = store.getProfile(m.profileId);

            const steps = store.getSteps(m.id);
            const readyForPastor = !!(steps.s1 && steps.s2 && steps.s3);
            const approved = !!m.approved;

            const presence = presenceByMatch[m.id] || {};
            const other: ChatSender = viewer === "Sender" ? "Receiver" : "Sender";

            const otherOnline = isOnlineStamp(presence[other]);
            const pastorOnline = isOnlineStamp(presence.Pastor);

            // unread per match
            const unread = store.unreadSummary?.byMatch?.[m.id] ?? 0;

            // last message preview (optional)
            const last = (store as any).lastMessageByMatch?.[m.id];
            const lastLine =
              last?.kind === "file"
                ? `📎 File: ${last?.file?.name || "attachment"}`
                : last?.text
                ? shortText(last.text, 84)
                : "";
            const lastWhen = formatTimeShort(last?.createdAt);

            // Compact approval status line
            const statusText = approved
              ? `✅ Approved • ${m.pastorName || "Pastor"}`
              : readyForPastor
              ? "✅ Ready for Pastor"
              : "🔒 Steps 1–3 required";

            const statusStyle = approved ? statusApproved : readyForPastor ? statusReady : statusLocked;

            const isOpen = openId === m.id;

            return (
              <div key={m.id} style={matchCard}>
                {/* TOP ROW */}
                <div style={cardTop}>
                  <div style={{ minWidth: 240 }}>
                    <div style={matchTitleRow}>
                      <div style={matchTitle}>
                        {p?.name || "Unknown"} <span style={smallDim}>• {p?.age || "—"}</span>
                      </div>

                      {unread > 0 ? <span style={unreadPill}>Unread {unread}</span> : <span style={unreadZero}>Unread 0</span>}
                    </div>

                    <div style={meta}>
                      {p?.city || "—"}, {p?.state || "—"} • {p?.faith || "—"} • Goal: <b>{p?.goal || "—"}</b>
                    </div>

                    {/* last message compact */}
                    <div style={lastRow}>
                      <span style={lastLabel}>Last:</span>
                      <span style={lastBubble}>{lastLine || "(No messages yet)"}</span>
                      {lastWhen ? <span style={lastTime}>{lastWhen}</span> : null}
                    </div>

                    {/* presence chips */}
                    <div style={chipsRow}>
                      <span style={otherOnline ? chipOnline : chipOffline}>
                        {other}: {otherOnline ? "🟢 Online" : "⚫ Offline"}
                      </span>
                      <span style={pastorOnline ? chipOnline : chipOffline}>
                        Pastor: {pastorOnline ? "🟢 Online" : "⚫ Offline"}
                      </span>
                    </div>
                  </div>

                  <div style={{ display: "grid", gap: 10, justifyItems: "end" }}>
                    <div style={statusStyle}>{statusText}</div>

                    {/* actions compact */}
                    <div style={{ display: "flex", gap: 10, flexWrap: "wrap", justifyContent: "flex-end" }}>
                      <Link style={btnGhostLink} href={`/dashboard/courtship/couple?matchId=${encodeURIComponent(m.id)}`}>
                        Couple
                      </Link>

                      {/* Pastor button: locked if not ready */}
                      {readyForPastor || approved ? (
                        <Link style={btnGoldLink} href={`/dashboard/courtship/pastor?matchId=${encodeURIComponent(m.id)}`}>
                          Pastor Proof
                        </Link>
                      ) : (
                        <button style={btnLocked} disabled title="Complete Steps 1–3 first">
                          Pastor Proof 🔒
                        </button>
                      )}

                      <button
                        style={btnSoft}
                        onClick={() => setOpenId((prev) => (prev === m.id ? null : m.id))}
                        title="Show/Hide details"
                      >
                        {isOpen ? "Hide" : "Details"}
                      </button>
                    </div>
                  </div>
                </div>

                {/* DETAILS (accordion) */}
                {isOpen ? (
                  <div style={detailsBox}>
                    <div style={detailsTitle}>Progress (Steps)</div>
                    <div style={stepsRow}>
                      <StepsChip ok={steps.s1} label={steps.s1 ? "1 ✅ Agreement" : "1 ⬜ Agreement"} />
                      <StepsChip ok={steps.s2} label={steps.s2 ? "2 ✅ Questions" : "2 ⬜ Questions"} />
                      <StepsChip ok={steps.s3} label={steps.s3 ? "3 ✅ Counseling Prep" : "3 ⬜ Counseling Prep"} />
                      <StepsChip ok={approved} label={approved ? "4 ✅ Approved" : "4 🔒 Pastor Only"} />
                    </div>

                    {!approved && !readyForPastor ? (
                      <div style={hint}>
                        ⚠️ Pastor approval ime-lock mpaka Steps 1–3 zikamilike. (Backend tayari inazuia pia.)
                      </div>
                    ) : null}

                    <div style={miniDivider} />

                    <div style={idRow}>
                      <span style={idChip}>Match ID: {m.id}</span>
                      <span style={idChip}>Profile ID: {m.profileId}</span>
                    </div>

                    <div style={{ display: "flex", gap: 10, flexWrap: "wrap", marginTop: 10 }}>
                      {/* ✅ profile route uses query param */}
                      <Link style={btnGhostLink} href={`/dashboard/courtship/profile?id=${encodeURIComponent(m.profileId)}`}>
                        View Profile
                      </Link>

                      <Link style={btnGhostLink} href="/dashboard/courtship/discover">
                        Back to Discover
                      </Link>
                    </div>
                  </div>
                ) : null}
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}

/* =========================
   STYLES
   ========================= */

const topRow: CSSProperties = {
  display: "flex",
  justifyContent: "space-between",
  alignItems: "flex-start",
  gap: 12,
  flexWrap: "wrap",
};

const pageTitle: CSSProperties = { fontSize: 34, fontWeight: 950, marginBottom: 6 };
const pageSub: CSSProperties = { opacity: 0.86, marginBottom: 12, lineHeight: 1.6 };

