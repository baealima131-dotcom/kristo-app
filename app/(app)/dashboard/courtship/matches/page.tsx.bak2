const stepsRow: CSSProperties = { display: "flex", gap: 8, flexWrap: "wrap" };

const chipOff: CSSProperties = {
  padding: "7px 10px",
  borderRadius: 999,
  border: "1px solid rgba(255,255,255,0.12)",
  background: "rgba(0,0,0,0.18)",
  fontWeight: 950,
  opacity: 0.9,
};

